# LLM Configuration — swap LLM_PROVIDER to change models, no code changes needed
LLM_PROVIDER=gemini                     # gemini | claude | openai
LLM_MODEL=gemini-2.5-flash             # model name for the chosen provider

# API Keys — only the active provider's key is required
GOOGLE_API_KEY=your_gemini_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# Supabase — use the service key (not anon key) for backend
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# Clerk — used to extract user_id from JWT
CLERK_SECRET_KEY=your_clerk_secret_key_here
