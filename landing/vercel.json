{
  "version": 2,
  "builds": [
    { "src": "**/*.{html,xml,txt}", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/demo.html",   "dest": "/demo.html" },
    { "src": "/sitemap.xml", "dest": "/sitemap.xml" },
    { "src": "/robots.txt",  "dest": "/robots.txt" },
    { "src": "/(.*)",        "dest": "/index.html" }
  ]
}
